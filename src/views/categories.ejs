<%- include("partials/header") %>

<main>
  <h2>Project Categories</h2>

  <ul class="category-list">

    <% categories.forEach(category => { %>

      <li>
        <a href="/category/<%= category.category_id %>">
          <%= category.name %>
        </a>
      </li>

    <% }) %>

  </ul>

</main>

<%- include("partials/footer") %>