<%- include("partials/header") %>

<main>
  <h2><%= project.title %></h2>

  <p><strong>Description:</strong> <%= project.description %></p>
  <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
  <p><strong>Location:</strong> <%= project.location %></p>

  <p>
    <strong>Organization:</strong>
    <a href="/organization/<%= project.organization_id %>">
      <%= project.organization_name %>
    </a>
  </p>

  <p>
    <a href="/projects">← Back to Projects</a>
  </p>

  <h3>Categories</h3>

<ul class="category-tags">
  <% categories.forEach(category => { %>
    <li>
      <a href="/category/<%= category.category_id %>">
        <%= category.name %>
      </a>
    </li>
  <% }) %>
</ul>

<% if (isLoggedIn) { %>
  <% if (isVolunteer) { %>
    <p>You are volunteering for this project.</p>
    <form method="POST" action="/project/<%= project.project_id %>/unvolunteer">
      <button type="submit">Remove Volunteer</button>
    </form>
  <% } else { %>
    <form method="POST" action="/project/<%= project.project_id %>/volunteer">
      <button type="submit">Volunteer</button>
    </form>
  <% } %>
<% } %>

<% if (user && user.role_name === 'admin') { %>
<a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
<p>
  <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
</p>
<% } %>

</main>



<%- include("partials/footer") %>