<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>

  <form action="/edit-category/<%= category.category_id %>" method="POST">
    <label>Category Name</label>
    <input 
      type="text" 
      name="name" 
      value="<%= category.name %>" 
      maxlength="100" 
      required 
    />

    <button type="submit">Update Category</button>
  </form>
</main>

<%- include('partials/footer') %>